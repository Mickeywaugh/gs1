{
    "name": "mickeywaugh/gs1",
    "description": "GS1 EPC编码解码库 - 支持SGTIN、GDTI等多种EPC方案",
    "type": "library",
    "keywords": [
        "gs1",
        "epc",
        "sgtin",
        "gdti",
        "rfid",
        "barcode",
        "encoding",
        "decoding",
        "supply-chain"
    ],
    "homepage": "https://github.com/mickeywaugh/gs1",
    "readme": "README.md",
    "time": "2025-01-01",
    "require": {
        "php": "^8.1",
        "ext-simplexml": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Mickeywaugh\\Gs1\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mickeywaugh\\Gs1\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Mickeywaugh",
            "email": "mickeywaugh@163.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/mickeywaugh/gs1/issues",
        "source": "https://github.com/mickeywaugh/gs1"
    },
    "funding": [],
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}