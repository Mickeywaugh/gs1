{
    "BINARY": {
        "type": "BINARY",
        "prefixMatch": "00101111",
        "requiredFormattingParameters": "filter,taglength",
        "option": {
            "optionKey": "1",
            "pattern": "\/^00101111([01]{4})([01]{48})([01]{36})$\/",
            "grammar": "'00101111' filter cageordodaac serial",
            "field": {
                "filter": {
                    "seq": "1",
                    "decimalMinimum": "0",
                    "decimalMaximum": "15",
                    "characterSet": "[01]*",
                    "bitPadDir": "LEFT",
                    "bitLength": "4",
                    "name": "filter"
                },
                "cageordodaac": {
                    "seq": "2",
                    "characterSet": "[01]*",
                    "compaction": "8-bit",
                    "padChar": " ",
                    "padDir": "LEFT",
                    "length": "6",
                    "bitLength": "48",
                    "name": "cageordodaac"
                },
                "serial": {
                    "seq": "3",
                    "decimalMinimum": "0",
                    "decimalMaximum": "68719476735",
                    "characterSet": "[01]*",
                    "bitPadDir": "LEFT",
                    "bitLength": "36",
                    "name": "serial"
                }
            }
        }
    },
    "PURE_IDENTITY": {
        "optionKey": "1",
        "pattern": "\/^urn:epc:id:usdod:([0-9A-HJ-NP-Z]{5,6})\\.([0-9]{1,11})$\/",
        "grammar": "'urn:epc:id:usdod:' cageordodaac '.' serial"
    },
    "TAG_ENCODING": {
        "optionKey": "1",
        "pattern": "\/^urn:epc:tag:usdod-96:([0-9]{1,2})\\.([0-9A-HJ-NP-Z]{5,6})\\.([0-9]{1,11})$\/",
        "grammar": "'urn:epc:tag:usdod-96:' filter '.' cageordodaac '.' serial"
    },
    "LEGACY": {
        "optionKey": "1",
        "pattern": "\/^cageordodaac=([0-9A-HJ-NP-Z]{5,6});serial=([0-9]{1,11})$\/",
        "grammar": "'cageordodaac=' cageordodaac ';serial=' serial"
    }
}